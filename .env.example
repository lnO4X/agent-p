# ===== REQUIRED =====

# Database (local: postgres://agent_p:agent_p_dev@localhost:5433/agent_p)
# Cloud: use Neon/Supabase pooled connection string with ?sslmode=require
DATABASE_URL=postgres://agent_p:agent_p_dev@localhost:5433/agent_p

# Authentication — MUST be stable (changing invalidates all sessions)
JWT_SECRET=change-me-to-a-random-32-char-string

# AI Chat (OpenRouter — https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===== OPTIONAL (features degrade gracefully without these) =====

# Redis — rate limiting + sessions (local: redis://localhost:6379)
# Cloud: use Upstash Redis URL (rediss://default:xxx@xxx.upstash.io:6379)
REDIS_URL=redis://localhost:6379

# AI model override (default: from DB site_settings, fallback: minimax/minimax-m2.5)
AI_MODEL=anthropic/claude-sonnet-4

# Email notifications (https://resend.com)
RESEND_API_KEY=re_xxxxx

# Game crawlers (https://firecrawl.dev)
FIRECRAWL_API_KEY=fc-xxxxx

# Steam game library import (https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=xxxxx

# Cron job auth (Bearer token for /api/cron/* and /api/admin/*)
CRON_SECRET=change-me-to-a-random-string

# Voice service (local GPU — not needed for Vercel deployment)
VOICE_SERVICE_URL=http://localhost:8100
VOICE_SERVICE_SECRET=voice-dev-secret
